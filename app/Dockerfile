# 1. Берем готовый официальный образ Линукса с установленным Python 3.9
FROM python:3.9-slim

# 2. Создаем папку /app внутри контейнера и делаем её рабочей
WORKDIR /app

# 3. Сначала копируем только список библиотек
COPY requirements.txt .

# 4. Просим Python установить эти библиотеки
RUN pip install --no-cache-dir -r requirements.txt

# 5. Теперь копируем весь остальной код (наш app.py) в контейнер
COPY . .

# 6. Говорим контейнеру, что он должен слушать порт 5000
EXPOSE 5000

# 7. Главная команда: как запускать наш сайт при старте контейнера
CMD ["python", "app.py"]
